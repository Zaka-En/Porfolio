---

---

<header
  class="flex justify-between items-center py-3 w-full xl:w-[1120px] mx-auto px-3 relative"
>
  <a href="">
    <img
      class="rounded-full w-14 h-14"
      src="/foto2.webp"
      alt="Photo Zakaria"
      loading="lazy"
    />
  </a>

  <nav class="hidden md:flex flex-row opacity-90">
    <!-- <a href="#">Home</a> -->
    <a href="#sobre-mi">Sobre mí</a>
    <a href="#proyectos">Proyectos</a>
    <a href="#habilidades">Tecnologías</a>
    <a href="#contacto">Contacto</a>
  </nav>

  <input type="checkbox" id="menu" class="peer hidden" />

  <label
    for="menu"
    class="md:hidden flex flex-col gap-1.5 w-8 cursor-pointer z-50"
  >
    <span class="bar"></span><span class="bar"></span><span class="bar"></span>
  </label>

  <nav
    class="md:hidden absolute top-full right-0 w-48 bg-black/95 flex flex-col gap-2 p-4 rounded-lg mt-2 opacity-0 pointer-events-none transition-opacity peer-checked:opacity-100 peer-checked:pointer-events-auto z-50"
  >
    <!--  <a href="#">Home</a> -->
    <a href="#sobre-mi">Sobre mí</a>
    <a href="#proyectos">Proyectos</a>
    <a href="#habilidades">Tecnologías</a>
    <a href="#contacto">Contacto</a>
  </nav>
</header>

<style>
  nav a {
    padding: 10px;
    transition: background-color 0.1s linear;
    border-radius: 4px;
    transition-delay: 0.1s;
    color: white;
  }
  nav a:hover {
    cursor: pointer;
    background-color: rgba(255, 255, 255, 0.1);
    transition-delay: 0s;
  }

  .bar {
    display: block;
    height: 3px;
    width: 100%;
    background-color: white;
    transition:
      transform 0.3s ease,
      opacity 0.3s ease;
    transform-origin: center;
  }

  #menu:checked ~ label .bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  #menu:checked ~ label .bar:nth-child(2) {
    transform: scaleX(
      0
    );
    opacity: 0;
  }

  #menu:checked ~ label .bar:nth-child(3) {
    transform: translateY(-11px) rotate(-45deg);
  }
</style>
