---
import HtmlIcon from "../icons/HtmlIcon.astro";
import JavascriptIcon from "../icons/JavascriptIcon.astro";
import CssIcon from "../icons/CssIcon.astro";
import PhpIcon from "../icons/PhpIcon.astro";
import LaravelIcon from "../icons/LaravelIcon.astro";
import DockerIcon from "../icons/DockerIcon.astro";
import VueIcon from "../icons/VueIcon.astro"
import GitIcon from "../icons/GitIcon.astro";
import SymfonyIcon from "../icons/SymfonyIcon.astro";
import RobotIcon from "../icons/RobotIcon.astro";

---

<div class="w-full">
  <div class="grid grid-cols-[repeat(auto-fit,minmax(100px,1fr))] gap-8 max-w-2xl mx-auto my-5">
    <!-- JavaScript -->
    <div class="flex flex-col items-center gap-3 hover:-translate-y-1 transition-transform group">
      <div class="w-20 h-20 rounded-full bg-white/5 backdrop-blur-md flex items-center justify-center border-2 border-white/10 relative overflow-hidden before:absolute before:inset-0 before:scale-200 before:opacity-0 before:transition-opacity before:bg-[radial-gradient(circle,rgba(234,179,8,0.4)_0%,transparent_70%)] group-hover:before:opacity-100">
        <JavascriptIcon />
      </div>
      <span class="text-white/70 text-sm font-medium group-hover:text-white transition-colors">JavaScript</span>
    </div>

    <!-- HTML5 -->
    <div class="flex flex-col items-center gap-3 hover:-translate-y-1 transition-transform group">
      <div class="w-20 h-20 rounded-full bg-white/5 backdrop-blur-md flex items-center justify-center border-2 border-white/10 relative overflow-hidden before:absolute before:inset-0 before:scale-200 before:opacity-0 before:transition-opacity before:bg-[radial-gradient(circle,rgba(249,115,22,0.4)_0%,transparent_70%)] group-hover:before:opacity-100">
        <HtmlIcon />
      </div>
      <span class="text-white/70 text-sm font-medium group-hover:text-white transition-colors">HTML5</span>
    </div>

    <!-- CSS3 -->
    <div class="flex flex-col items-center gap-3 hover:-translate-y-1 transition-transform group">
      <div class="w-20 h-20 rounded-full bg-white/5 backdrop-blur-md flex items-center justify-center border-2 border-white/10 relative overflow-hidden before:absolute before:inset-0 before:scale-200 before:opacity-0 before:transition-opacity before:bg-[radial-gradient(circle,rgba(59,130,246,0.4)_0%,transparent_70%)] group-hover:before:opacity-100">
        <CssIcon />
      </div>
      <span class="text-white/70 text-sm font-medium group-hover:text-white transition-colors">CSS3</span>
    </div>

    <!-- PHP -->
    <div class="flex flex-col items-center gap-3 hover:-translate-y-1 transition-transform group">
      <div class="w-20 h-20 rounded-full bg-white/5 backdrop-blur-md flex items-center justify-center border-2 border-white/10 relative overflow-hidden before:absolute before:inset-0 before:scale-200 before:opacity-0 before:transition-opacity before:bg-[radial-gradient(circle,rgba(168,85,247,0.4)_0%,transparent_70%)] group-hover:before:opacity-100">
        <PhpIcon />
      </div>
      <span class="text-white/70 text-sm font-medium group-hover:text-white transition-colors">PHP</span>
    </div>

    <!-- Laravel -->
    <div class="flex flex-col items-center gap-3 hover:-translate-y-1 transition-transform group">
      <div class="w-20 h-20 rounded-full bg-white/5 backdrop-blur-md flex items-center justify-center border-2 border-white/10 relative overflow-hidden before:absolute before:inset-0 before:scale-200 before:opacity-0 before:transition-opacity before:bg-[radial-gradient(circle,rgba(239,68,68,0.4)_0%,transparent_70%)] group-hover:before:opacity-100">
        <LaravelIcon />
      </div>
      <span class="text-white/70 text-sm font-medium group-hover:text-white transition-colors">Laravel</span>
    </div>

    <!-- Docker -->
    <div class="flex flex-col items-center gap-3 hover:-translate-y-1 transition-transform group">
      <div class="w-20 h-20 rounded-full bg-white/5 backdrop-blur-md flex items-center justify-center border-2 border-white/10 relative overflow-hidden before:absolute before:inset-0 before:scale-200 before:opacity-0 before:transition-opacity before:bg-[radial-gradient(circle,rgba(59,130,246,0.4)_0%,transparent_70%)] group-hover:before:opacity-100">
        <DockerIcon />
      </div>
      <span class="text-white/70 text-sm font-medium group-hover:text-white transition-colors">Docker</span>
    </div>

    <!-- Git -->
    <div class="flex flex-col items-center gap-3 hover:-translate-y-1 transition-transform group">
      <div class="w-20 h-20 rounded-full bg-white/5 backdrop-blur-md flex items-center justify-center border-2 border-white/10 relative overflow-hidden before:absolute before:inset-0 before:scale-200 before:opacity-0 before:transition-opacity before:bg-[radial-gradient(circle,rgba(249,115,22,0.4)_0%,transparent_70%)] group-hover:before:opacity-100">
        <GitIcon />
      </div>
      <span class="text-white/70 text-sm font-medium group-hover:text-white transition-colors">Git</span>
    </div>

    <!-- Vue -->
    <div class="flex flex-col items-center gap-3 hover:-translate-y-1 transition-transform group">
      <div class="w-20 h-20 rounded-full bg-white/5 backdrop-blur-md flex items-center justify-center border-2 border-white/10 relative overflow-hidden before:absolute before:inset-0 before:scale-200 before:opacity-0 before:transition-opacity before:bg-[radial-gradient(circle,rgba(34,197,94,0.4)_0%,transparent_70%)] group-hover:before:opacity-100">
        <VueIcon />
      </div>
      <span class="text-white/70 text-sm font-medium group-hover:text-white transition-colors">Vue</span>
    </div>

    <!-- Symfony -->
    <div class="flex flex-col items-center gap-3 hover:-translate-y-1 transition-transform group">
      <div class="w-20 h-20 rounded-full bg-white/5 backdrop-blur-md flex items-center justify-center border-2 border-white/10 relative overflow-hidden before:absolute before:inset-0 before:scale-200 before:opacity-0 before:transition-opacity before:bg-[radial-gradient(circle,rgba(168,85,247,0.4)_0%,transparent_70%)] group-hover:before:opacity-100">
        <SymfonyIcon />
      </div>
      <span class="text-white/70 text-sm font-medium group-hover:text-white transition-colors">Symfony</span>
    </div>

    <!-- Crew AI -->
    <div class="flex flex-col items-center gap-3 hover:-translate-y-1 transition-transform group">
      <div class="w-20 h-20 rounded-full bg-white/5 backdrop-blur-md flex items-center justify-center border-2 border-white/10 relative overflow-hidden before:absolute before:inset-0 before:scale-200 before:opacity-0 before:transition-opacity before:bg-[radial-gradient(circle,rgba(239,68,68,0.4)_0%,transparent_70%)] group-hover:before:opacity-100">
        <RobotIcon />
      </div>
      <span class="text-white/70 text-sm font-medium group-hover:text-white transition-colors">Crew AI</span>
    </div>
    
  </div>
</div>

<style>
  @keyframes blur-pulse {
    0%, 100% {
      transform: scale(1);
      filter: blur(20px);
    }
    50% {
      transform: scale(1.1);
      filter: blur(30px);
    }
  }

  .animate-blur-pulse {
    animation: blur-pulse 1.5s ease-in-out infinite;
  }
</style>