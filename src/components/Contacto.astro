---
import StatusBadge from "./StatusBadge.astro";

// Reusable input styles
const inputClass =
  "mb-4 shadow-sm bg-transparent border border-gray-300 text-white placeholder-gray-400 text-sm rounded-lg focus:ring-primary-500 focus:border-primary-500 block w-full p-2.5 dark:border-gray-600 dark:text-white dark:placeholder-gray-400 dark:focus:ring-primary-500 dark:focus:border-primary-500 dark:shadow-sm-light";
---

<div class="py-3 lg:py-10 px-4 mx-auto max-w-screen-md">
  <form id="contactForm" class="space-y-6">
    <!-- Email -->
    <div>
      <label
        for="email"
        class="block mb-2 text-sm font-medium dark:text-gray-300"
      >
        Correo
      </label>
      <input
        type="email"
        id="email"
        name="email"
        class={inputClass}
        placeholder="name@email.com"
        required
      />
    </div>

    <!-- Nombre -->
    <div>
      <label
        for="nombre"
        class="block mb-2 text-sm font-medium dark:text-gray-300"
      >
        Nombre
      </label>
      <input
        type="text"
        id="nombre"
        name="nombre"
        class={inputClass}
        placeholder="Menganito"
        required
      />
    </div>

    <!-- Asunto -->
    <div>
      <label
        for="asunto"
        class="block mb-2 text-sm font-medium dark:text-gray-300"
      >
        Asunto
      </label>
      <input
        type="text"
        id="asunto"
        name="asunto"
        class={inputClass}
        placeholder="Oferta de trabajo..."
        required
      />
    </div>

    <!-- Mensaje -->
    <div>
      <label
        for="mensaje"
        class="block mb-2 text-sm font-medium text-white dark:text-gray-300"
      >
        Mensaje
      </label>
      <textarea
        id="mensaje"
        rows="6"
        name="mensaje"
        class={inputClass}
        placeholder="Deja un mensaje..."
        required></textarea>
    </div>

    <!-- Submit -->
    <button
      type="submit"
      class="py-3 px-3 text-sm font-medium text-center text-white rounded-lg bg-primary-700 sm:w-fit hover:bg-primary-800 focus:ring-4 focus:outline-none focus:ring-primary-300 dark:bg-primary-600 dark:hover:bg-primary-700 dark:focus:ring-primary-800 hover:bg-white/10 cursor-pointer"
    >
      Enviar
    </button>

    <!-- Status Badges -->
    <StatusBadge id="okBadge" status="success">Enviado correctamente</StatusBadge>
    <StatusBadge id="failBadge" status="fail">Error al enviar</StatusBadge>
  </form>
</div>

<script>
  import emailjs from "@emailjs/browser";

  
  const PUBLIC_KEY = import.meta.env.PUBLIC_EMAILJS_PUBLIC_KEY;
  const SERVICE_ID = import.meta.env.PUBLIC_EMAILJS_SERVICE_ID;
  const TEMPLATE_ID = import.meta.env.PUBLIC_EMAILJS_TEMPLATE_ID;

  emailjs.init(PUBLIC_KEY);

  const form = document.getElementById("contactForm");
  const okBadge = document.getElementById("okBadge");
  const failBadge = document.getElementById("failBadge");

  form.addEventListener("submit", async (e) => {
    e.preventDefault();

    const data = {
      from_email: form.email.value,
      subject: form.asunto.value,
      message: form.mensaje.value,
      name: form.nombre.value,
    };

    try {
      await emailjs.send(SERVICE_ID, TEMPLATE_ID, data);

      failBadge.classList.add("hidden");
      okBadge.classList.remove("hidden");

      setTimeout(() => {
        form.reset();
        okBadge.classList.add("hidden");
      }, 3000);
    } catch (err) {
      console.error(err);

      okBadge.classList.add("hidden");
      failBadge.classList.remove("hidden");

      setTimeout(() => {
        failBadge.classList.add("hidden");
      }, 3000);
    }
  });
</script>
