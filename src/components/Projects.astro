---
import GithubIcon from "../icons/GithubIcon.astro";
const PROJECTS = [
  {
    title: "Venta Coches",
    description: "Aplicación web para la compra y venta de vehículos desarrollada con Laravel 12. Sistema completo de gestión de usuarios, vehículos y características avanzadas de búsqueda con filtros dinámicos.",
    link: "",
    github: "https://github.com/Zaka-En/venta-coches",
    image: "/venta-coches.png",
    tags: ["Laravel", "PHP", "Blade", "SQLite", "JavaScript", "CSS"],
  },
];
---

{
  PROJECTS.map(({ title, description, link, github, image, tags }) => (
    <article class="flex flex-col my-3 hover:-translate-y-1 transition-transform duration-300">
      <a
        href={link || github}
        target="_blank"
        rel="noopener noreferrer"
        class="flex flex-col w-full items-stretch bg-[#19141c3e] backdrop-blur-sm border border-gray-700 rounded-lg shadow-sm md:flex-row md:max-w-full hover:border-gray-600 transition-colors overflow-hidden"
      >
        <img
          loading="lazy"
          class="object-cover w-full h-64 md:h-auto md:w-80"
          src={image || "../../public/foto.jpg"}
          alt={title}
        />
        <div class="flex flex-col justify-between p-4 leading-normal w-full">
          <div>
            <h5 class="mb-2 text-2xl font-bold tracking-tight text-white">
              {title}
            </h5>
            <p class="mb-3 font-normal text-white">
              {description}
            </p>
          </div>
          <div class="flex flex-wrap gap-2 mt-2">
            {tags.map((tag) => (
              <span class="px-3 py-1 text-xs font-medium text-gray-300 bg-gray-700/50 rounded-full">
                {tag}
              </span>
            ))}
          </div>
          <div class="flex gap-4 mt-4">
            {link && (
              <span class="text-sm text-blue-400 hover:text-blue-300 flex items-center gap-1">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                </svg>
                Demo
              </span>
            )}
            {github && (
              <span class="text-sm text-blue-400 hover:text-blue-300 flex items-center gap-1">
                <GithubIcon class="w-4 h-4" />
                GitHub
                 
              </span>
            )}
          </div>
        </div>
      </a>
    </article>
  ))
}